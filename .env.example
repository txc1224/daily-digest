# 每日简报环境变量配置

# ========== 必需 ==========
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxx

# ========== 可选 ==========

# 天气城市（默认 Beijing）
WEATHER_CITY=Beijing

# AI 摘要功能（可选）
# - 有 Key：使用 Claude API 生成高质量摘要
# - 无 Key：使用本地规则自动提取关键信息
ANTHROPIC_API_KEY=sk-ant-api-xxxxx

# Product Hunt Token（可选）
# - 有 Token：使用 Product Hunt API 获取数据
# - 无 Token：使用 RSS 备用方案
PRODUCT_HUNT_TOKEN=
